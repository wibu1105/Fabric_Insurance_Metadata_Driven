table _measure
	lineageTag: 68986969-63bb-4556-a2ab-062713ed6b78

	measure 'Issue Policy' = ```
			
			VAR IssuedCount = 
			    CALCULATE(
			        DISTINCTCOUNT('FactPolicy'[policy_info_key])
			    )
			
			RETURN
			    COALESCE(IssuedCount, 0)
			```
		formatString: 0
		lineageTag: 4f2ee813-13f4-4c78-a9a1-b682396d3898

	measure 'Active Policies' =
			
			VAR SelectedDate =
			    MAX ( 'dimdate'[full_date] )
			
			VAR HasRestrictedDateSelection =
			    ISCROSSFILTERED ( 'dimdate' )
			
			RETURN
			IF (
			    HasRestrictedDateSelection,
			
			    -- Case 1: Month-Year or date range selected.
			    -- Count policies active as of the selected period end date.
			    CALCULATE (
			        COUNTROWS ( 'DimPolicyInfo' ),
			        REMOVEFILTERS ( 'dimdate' ),
			        'DimPolicyInfo'[is_deleted] = FALSE (),
			        'DimPolicyInfo'[policy_start_date] <= SelectedDate,
			        'DimPolicyInfo'[policy_end_date] >= SelectedDate
			            || ISBLANK ( 'DimPolicyInfo'[policy_end_date] )
			    ),
			
			    -- Case 2: Time slicer is All.
			    -- Count policies whose current business status is ACTIVE.
			    CALCULATE (
			        DISTINCTCOUNT ( 'FactPolicy'[policy_info_key] ),
			        REMOVEFILTERS ( 'dimdate' ),
			        'DimPolicyInfo'[is_deleted] = FALSE (),
			        'FactPolicy'[policy_status] = "ACTIVE"
			    )
			)
		formatString: 0
		lineageTag: 3956c61e-7463-4cdb-83f7-a3dae66fb295

	measure 'Active Customers' =
			
			CALCULATE (
			    DISTINCTCOUNT ( factpolicy[customer_key] ),
			    factpolicy[policy_status] = "ACTIVE"
			)
		formatString: 0
		lineageTag: e41b1f2f-8dd7-49da-94ce-4544fe82b01f

	measure 'Actual Collected Premium' = ```
			
			VAR GrossPaid = 
			    CALCULATE(
			        SUM('FactPayment'[payment_amount]),
			        'FactPayment'[payment_status] = "PAID"
			    )
			
			VAR RefundedAmount = 
			    CALCULATE(
			        SUM('FactPayment'[payment_amount]),
			        'FactPayment'[payment_status] = "REFUNDED"
			    )
			
			RETURN 
			    COALESCE(GrossPaid, 0) - COALESCE(RefundedAmount, 0)
			```
		lineageTag: 432d7bde-6400-4ffc-b971-604448188fc3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Paid Premium' =
			
			CALCULATE(
			    SUM('FactPayment'[payment_amount]),
			    'FactPayment'[payment_status] = "PAID"
			)
		lineageTag: 305392ee-77b8-4579-95ce-e7e4dabf2498

		annotation PBI_FormatHint = {"isGeneralNumber":true}

