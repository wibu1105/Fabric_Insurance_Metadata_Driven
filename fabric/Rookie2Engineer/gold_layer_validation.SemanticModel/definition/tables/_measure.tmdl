	measure 'Failed Payment' =
			
			CALCULATE(
			    SUM('FactPayment'[payment_amount]),
			    'FactPayment'[payment_status] = "FAILED"
			)
		lineageTag: 800f2835-e4a1-4723-ba67-32f1863aa98d

