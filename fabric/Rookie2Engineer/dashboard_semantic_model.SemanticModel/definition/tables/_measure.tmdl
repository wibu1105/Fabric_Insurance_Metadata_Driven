	measure 'Issue Policy' = ```
			
			VAR IssuedCount = 
			    CALCULATE(
			        DISTINCTCOUNT('FactPolicy'[policy_info_key])
			        //'FactPolicy'[policy_status] = "ISSUED" 
			    )
			
			RETURN
			    COALESCE(IssuedCount, 0)
			```
		formatString: 0
		lineageTag: 93fa3bed-9b47-404a-9651-9b2fcf610a06

	measure 'Policies MoM % Growth' = ```
			
			
			// --- 1. GET CURRENT METRIC ---
			VAR CurrentPolicies = DISTINCTCOUNT('factpolicy'[policy_info_key])
			
			// --- 2. SAFELY GET PREVIOUS METRIC ---
			VAR CurrentDate = MAX('dimdate'[full_date])
			VAR PreviousDate = EDATE(CurrentDate, -1)
			VAR TargetYear = YEAR(PreviousDate)
			VAR TargetMonth = MONTH(PreviousDate)
			
			VAR LastMonthPolicies = 
			    CALCULATE(
			        DISTINCTCOUNT('factpolicy'[policy_info_key]),
			        REMOVEFILTERS('dimdate'),
			        'dimdate'[year_number] = TargetYear,
			        'dimdate'[month_number] = TargetMonth
			    )
			
			// --- 3. CALCULATE % GROWTH ---
			RETURN
			    DIVIDE(
			        CurrentPolicies - LastMonthPolicies,
			        LastMonthPolicies,
			        BLANK()
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 2c83151e-d44b-43a3-8687-b2d6b9917ed5

	measure 'Last Batch Run Time' = ```
			
			VAR LatestSuccessBatch = 
			    CALCULATE(
			        MAX('audit_batch_log'[session_end]),
			        'audit_batch_log'[batch_status] = "success"
			    )
			    
			VAR LastSuccessTime = 
			    IF(
			        ISBLANK(LatestSuccessBatch),
			        "No Successful Runs",
			        FORMAT(LatestSuccessBatch, "dd-MMM-yyyy HH:mm:ss")
			    )
			
			RETURN "Last Updated: " & LastSuccessTime
			```
		lineageTag: fe8a505b-18a7-4f6d-a278-6f47f692dda4

	measure 'Payment Success Rate MoM % Growth' = ```
			
			// 1. Get the current rate
			VAR CurrentSuccessRate = [Payment Success Rate]
			
			// 2. Safely get the previous month's rate
			VAR CurrentDate = MAX('dimdate'[full_date])
			VAR PreviousDate = EDATE(CurrentDate, -1)
			VAR TargetYear = YEAR(PreviousDate)
			VAR TargetMonth = MONTH(PreviousDate)
			
			VAR LastMonthSuccessRate = 
			    CALCULATE(
			        [Payment Success Rate],
			        REMOVEFILTERS('dimdate'),
			        'dimdate'[year_number] = TargetYear,
			        'dimdate'[month_number] = TargetMonth
			    )
			
			// 3. Calculate the relative growth
			RETURN
			    DIVIDE(
			        CurrentSuccessRate - LastMonthSuccessRate,
			        LastMonthSuccessRate,
			        BLANK()
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 13762444-902b-4397-a217-f31ebf19ac14

	measure _measure
