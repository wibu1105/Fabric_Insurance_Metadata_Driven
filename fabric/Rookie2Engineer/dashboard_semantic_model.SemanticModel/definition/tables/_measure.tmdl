	measure 'Conversion Rate %MoM' =
			
			VAR CurrDate = MAX ( dimdate[full_date] )
			VAR PrevDate = EDATE ( CurrDate, -1 )
			VAR CurrVal =
			    CALCULATE (
			        [Conversion Rate],
			        REMOVEFILTERS ( dimdate ),
			        dimdate[year_number] = YEAR ( CurrDate ),
			        dimdate[month_number] = MONTH ( CurrDate )
			    )
			VAR PrevVal =
			    CALCULATE (
			        [Conversion Rate],
			        REMOVEFILTERS ( dimdate ),
			        dimdate[year_number] = YEAR ( PrevDate ),
			        dimdate[month_number] = MONTH ( PrevDate )
			    )
			RETURN
			    IF ( NOT ISBLANK ( PrevVal ), CurrVal - PrevVal )
			-- format: +0.0%;-0.0%   -- percentage-POINT delta (rate vs rate)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 7bd9bd72-d1f1-41a2-b603-b507c3d168e5

