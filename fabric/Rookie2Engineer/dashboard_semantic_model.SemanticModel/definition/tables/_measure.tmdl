	measure 'Payment Success Rate' = ```
			
			VAR PaymentCount = DISTINCTCOUNT('FactPayment'[payment_id])
			
			VAR SuccessfulPaymentCount = 
			    CALCULATE(
			        DISTINCTCOUNT('FactPayment'[payment_id]),
			        'FactPayment'[payment_status] = "PAID"
			    )
			
			RETURN 
			    DIVIDE(
			        SuccessfulPaymentCount, 
			        PaymentCount, 
			        BLANK()
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: b91559a5-5300-41bd-b70c-880b18a1265d

	measure 'Active Policies' =
			
			VAR SelectedDate =
			    MAX ( 'dimdate'[full_date] )
			
			VAR HasRestrictedDateSelection =
			    ISCROSSFILTERED ( 'dimdate' )
			
			RETURN
			IF (
			    HasRestrictedDateSelection,
			
			    -- Case 1: Month-Year or date range selected.
			    -- Count policies active as of the selected period end date.
			    CALCULATE (
			        COUNTROWS ( 'DimPolicyInfo' ),
			        REMOVEFILTERS ( 'dimdate' ),
			        'DimPolicyInfo'[is_deleted] = FALSE (),
			        'DimPolicyInfo'[policy_start_date] <= SelectedDate,
			        'DimPolicyInfo'[policy_end_date] >= SelectedDate
			            || ISBLANK ( 'DimPolicyInfo'[policy_end_date] )
			    ),
			
			    -- Case 2: Time slicer is All.
			    -- Count policies whose current business status is ACTIVE.
			    CALCULATE (
			        DISTINCTCOUNT ( 'FactPolicy'[policy_info_key] ),
			        REMOVEFILTERS ( 'dimdate' ),
			        'DimPolicyInfo'[is_deleted] = FALSE (),
			        'FactPolicy'[policy_status] = "ACTIVE"
			    )
			)
		formatString: 0
		lineageTag: c183254d-fd8f-47b1-8f1b-334c7eb1f582

	measure 'Issue Policy MoM % Growth' = ```
			
			VAR CurrentIssued = [Issue Policy]
			
			VAR CurrentDate = MAX('dimdate'[full_date])
			VAR PreviousDate = EDATE(CurrentDate, -1)
			VAR TargetYear = YEAR(PreviousDate)
			VAR TargetMonth = MONTH(PreviousDate)
			
			VAR LastMonthIssued = 
			    CALCULATE(
			        [Issue Policy],
			        REMOVEFILTERS('dimdate'),
			        'dimdate'[year_number] = TargetYear,
			        'dimdate'[month_number] = TargetMonth
			    )
			
			RETURN
			    DIVIDE(CurrentIssued - LastMonthIssued, LastMonthIssued, BLANK())
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: e90079b1-bd6f-4ddf-a28b-a42cf997dbbe

	measure 'Active Policies MoM % Growth' =
			
			VAR HasRestrictedDateSelection =
			    ISCROSSFILTERED ( 'dimdate' )
			
			VAR CurrentDate =
			    MAX ( 'dimdate'[full_date] )
			
			VAR PreviousDate =
			    EDATE ( CurrentDate, -1 )
			
			VAR CurrentActive =
			    [Active Policies]
			
			VAR PreviousActive =
			    CALCULATE (
			        COUNTROWS ( 'DimPolicyInfo' ),
			        REMOVEFILTERS ( 'dimdate' ),
			        'DimPolicyInfo'[is_deleted] = FALSE (),
			        'DimPolicyInfo'[policy_start_date] <= PreviousDate,
			        'DimPolicyInfo'[policy_end_date] >= PreviousDate
			            || ISBLANK ( 'DimPolicyInfo'[policy_end_date] )
			    )
			
			RETURN
			    IF (
			        NOT HasRestrictedDateSelection,
			        BLANK (),
			        DIVIDE (
			            CurrentActive - PreviousActive,
			            PreviousActive,
			            BLANK ()
			        )
			    )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 6457420b-eaac-461b-b816-769163bd6ade

