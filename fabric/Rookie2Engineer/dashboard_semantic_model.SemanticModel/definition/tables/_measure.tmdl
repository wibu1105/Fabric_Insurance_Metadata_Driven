	measure 'Cancellation Rate' =
			
			VAR CancelledCount =
			    CALCULATE (
			        DISTINCTCOUNT ( 'FactCancellation'[policy_info_key] ),
			        'DimPolicyInfo'[is_deleted] = FALSE ()
			    )
			
			VAR IssuedCount =
			    CALCULATE (
			        DISTINCTCOUNT ( 'FactPolicy'[policy_info_key] ),
			        'DimPolicyInfo'[is_deleted] = FALSE ()
			    )
			
			RETURN
			    DIVIDE ( CancelledCount, IssuedCount, 0 )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: eb3e27c9-8577-4515-99e3-34d21647188d

	measure 'Cancellation Rate MoM % Growth' =
			
			VAR HasRestrictedDateSelection =
			    ISCROSSFILTERED ( 'dimdate' )
			
			VAR CurrentRate =
			    [Cancellation Rate]
			
			VAR CurrentDate =
			    MAX ( 'dimdate'[full_date] )
			
			VAR PreviousDate =
			    EDATE ( CurrentDate, -1 )
			
			VAR TargetYear =
			    YEAR ( PreviousDate )
			
			VAR TargetMonth =
			    MONTH ( PreviousDate )
			
			VAR LastMonthRate =
			    CALCULATE (
			        [Cancellation Rate],
			        REMOVEFILTERS ( 'dimdate' ),
			        'dimdate'[year_number] = TargetYear,
			        'dimdate'[month_number] = TargetMonth
			    )
			
			RETURN
			    IF (
			        NOT HasRestrictedDateSelection,
			        BLANK (),
			        SWITCH (
			            TRUE (),
			
			            -- Previous month has no value or zero, current month has value.
			            -- Business rule: show 100% growth.
			            ( ISBLANK ( LastMonthRate ) || LastMonthRate = 0 )
			                && NOT ISBLANK ( CurrentRate )
			                && CurrentRate > 0,
			                1,
			
			            -- Previous month has no value/zero and current is also blank/zero.
			            -- No growth to report.
			            ISBLANK ( LastMonthRate ) || LastMonthRate = 0,
			                BLANK (),
			
			            -- Normal MoM % growth.
			            DIVIDE (
			                CurrentRate - LastMonthRate,
			                LastMonthRate,
			                BLANK ()
			            )
			        )
			    )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 3c3632e4-c745-49cf-9256-310ae92e5036

