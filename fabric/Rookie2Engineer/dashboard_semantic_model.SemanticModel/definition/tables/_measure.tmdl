	measure 'Total Quotations %MoM' =
			
			VAR CurrentVal = [Total Quotations]
			VAR PrevDate = EDATE ( MAX ( dimdate[full_date] ), -1 )
			VAR PrevVal =
			    CALCULATE (
			        [Total Quotations],
			        REMOVEFILTERS ( dimdate ),
			        dimdate[year_number] = YEAR ( PrevDate ),
			        dimdate[month_number] = MONTH ( PrevDate )
			    )
			RETURN
			    DIVIDE ( CurrentVal - PrevVal, PrevVal )
			-- format: +0.0%;-0.0%
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: e79e63d3-5472-4ebd-8f8c-95bf0b9e5c2f

