	measure 'Provider Bar Color By Conversion Rate' =
			
			VAR CurrentRank =
			    RANKX(
			        ALLSELECTED('dimprovider'[provider_name]),
			        [Conversion Rate],
			        ,
			        DESC
			    )
			RETURN
			SWITCH(
			    TRUE(),
			    CurrentRank = 1, "#6A1F7A",   -- Dark Purple
			    CurrentRank <= 3, "#815AC0",  -- Medium Purple
			    "#A06CD5"                     -- Light Purple
			)
		lineageTag: 32b193ea-1d51-46d0-b397-a61359d9d627

