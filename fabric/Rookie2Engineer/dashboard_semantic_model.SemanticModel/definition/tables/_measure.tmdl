	measure 'Paid Premium MoM % Growth' = ```
			
			VAR CurrentPremium = [Paid Premium]
			
			// Safely target exactly one month prior
			VAR CurrentDate = MAX('dimdate'[full_date])
			VAR PreviousDate = EDATE(CurrentDate, -1)
			VAR TargetYear = YEAR(PreviousDate)
			VAR TargetMonth = MONTH(PreviousDate)
			
			VAR LastMonthPremium = 
			    CALCULATE(
			        [Paid Premium],
			        REMOVEFILTERS('dimdate'),
			        'dimdate'[year_number] = TargetYear,
			        'dimdate'[month_number] = TargetMonth
			    )
			
			RETURN
			    DIVIDE(
			        CurrentPremium - LastMonthPremium, 
			        LastMonthPremium, 
			        BLANK()
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 789c83ed-750e-4447-a0c0-aa6206adcef8

