model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-001
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["DirectQuery to AS - dashboard_semantic_model","Aging Bands"]

annotation PBI_ProTooling = ["WebModelingEdit"]

ref table factpolicy
ref table dimquotationinfo
ref table dimvehicle
ref table factcancellation
ref table dimprovider
ref table factquotationitem
ref table dimagent
ref table dimcustomer
ref table dimpaymenttype
ref table dimdate
ref table factpayment
ref table dimpolicyinfo
ref table _measure
ref table 'Aging Bands'
ref table FlowMap
ref table audit_batch_log

ref cultureInfo en-US

