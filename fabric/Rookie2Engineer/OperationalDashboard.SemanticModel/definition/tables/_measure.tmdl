	measure 'Pending Count by Band' =
			
			SWITCH(
			    SELECTEDVALUE('Aging Bands'[Band]),
			    "0-7 days", [Pending Count 0-7 days],
			    "8-30 days", [Pending Count 8-30 days],
			    "31-60 days", [Pending Count 31-60 days],
			    "61-90 days", [Pending Count 61-90 days],
			    ">90 days", [Pending Count >90 days]
			)
		formatString: 0
		lineageTag: f1469bcd-f768-4516-8bcd-02cdbc747398

