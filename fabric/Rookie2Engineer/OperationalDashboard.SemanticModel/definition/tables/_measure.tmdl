	measure 'Measure 6' =
			
			VAR SelectedDate =
			    MAX ( 'dimdate'[full_date] )
			
			VAR HasRestrictedDateSelection =
			    ISCROSSFILTERED('dimdate')
			
			RETURN
			IF (
			    HasRestrictedDateSelection,
			
			    -- Case 1: Month-Year or date range selected.
			    -- Count policies active as of the selected period end date.
			    CALCULATE (
			        COUNTROWS ( 'DimPolicyInfo' ),
			        'DimPolicyInfo'[is_deleted] = FALSE (),
			        'FactPolicy'[policy_status] = "ACTIVE",
			        'DimPolicyInfo'[policy_start_date] <= SelectedDate,
			        'DimPolicyInfo'[policy_end_date] >= SelectedDate
			            || ISBLANK ( 'DimPolicyInfo'[policy_end_date] )
			    ),
			
			    -- Case 2: Time slicer is All.
			    -- Count policies whose current business status is ACTIVE.
			    CALCULATE (
			        DISTINCTCOUNT ( 'FactPolicy'[policy_info_key] ),
			        REMOVEFILTERS ( 'dimdate' ),
			        'DimPolicyInfo'[is_deleted] = FALSE (),
			        'FactPolicy'[policy_status] = "ACTIVE"
			    )
			)
		formatString: 0
		lineageTag: 497b5b9b-9881-4116-88d8-e972b60fa989

	measure 'Measure 7' =
			
			VAR SelectedDate =
			    MAX('dimdate'[full_date])
			
			RETURN
			CALCULATE(
			    DISTINCTCOUNT('FactPolicy'[policy_info_key]),
			    'DimPolicyInfo'[is_deleted] = FALSE(),
			    'DimPolicyInfo'[policy_start_date] <= SelectedDate,
			    ISBLANK('DimPolicyInfo'[policy_end_date])
			        || 'DimPolicyInfo'[policy_end_date] >= SelectedDate,
			    'FactPolicy'[policy_status] = "ACTIVE"
			)
		formatString: 0
		lineageTag: d7015b4d-9993-4f10-aac1-783ab8ab89b5

	column Column
		dataType: int64
		formatString: 0
		lineageTag: 821943da-e930-41aa-bc9f-4b2fca473dc9
		sourceLineageTag: 124539de-f015-4070-8f69-6d7a56d3fa5e
		dataCategory: Uncategorized
		summarizeBy: sum
		sourceColumn: Column

		annotation SummarizationSetBy = User

	partition _measure = entity
		mode: directQuery
		source
			entityName: _measure
			expressionSource: 'DirectQuery to AS - dashboard_semantic_model'

