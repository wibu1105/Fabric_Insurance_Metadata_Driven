DEMO_MODE=false
PORT=8080
SESSION_SECRET=
SESSION_COOKIE_SECURE=false
SESSION_MAX_AGE_MS=28800000
FRONTEND_APP_URL=http://localhost:5173

# Microsoft interactive admin login.
# Register this redirect URI on the app registration:
# http://localhost:5173/api/auth/microsoft/callback for local Vite development
# or http://localhost:8080/api/auth/microsoft/callback when testing the built Express app directly.
MICROSOFT_REDIRECT_URI=http://localhost:5173/api/auth/microsoft/callback
POWERBI_AUTH_SCOPES=https://analysis.windows.net/powerbi/api/.default

# Required when DEMO_MODE=false. CLIENT_ID is the Application (client) ID GUID.
# CLIENT_SECRET is the secret Value, not the Secret ID.
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# Fabric Warehouse used by the mock web login and password update flow.
AUDIT_WAREHOUSE_NAME=
AUDIT_WAREHOUSE_WORKSPACE_ID=
AUDIT_WAREHOUSE_ID=
AUDIT_WAREHOUSE_SQL_ENDPOINT=
APP_USERS_USER_MAIL_COLUMN=user_mail
POWERBI_RLS_ROLE=rls_level

