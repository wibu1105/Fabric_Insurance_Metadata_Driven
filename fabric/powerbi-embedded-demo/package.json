{
  "name": "powerbi-embedded-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node --env-file=.env server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext js,jsx --max-warnings 0"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.4",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "mssql": "^12.5.5",
    "powerbi-client": "^2.23.7",
    "powerbi-client-react": "^2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "concurrently": "^10.0.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^25.0.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
