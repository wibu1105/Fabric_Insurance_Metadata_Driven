        "name": "FE_Recover_Failed_Bronze_Tables",
        "dependsOn": [
          {
            "activity": "SQL_Get_Failed_Bronze_Tables",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ]
      },
      {
        "type": "Script",
        "typeProperties": {
          "scripts": [
            {
              "text": {
                "value": "DECLARE @audit_batch_id VARCHAR(100) = '@{replace(string(pipeline().parameters.p_audit_batch_id), '''', '''''')}';\nDECLARE @target_layer VARCHAR(100) = 'bronze';\n\nUPDATE s\nSET\n    session_status = 'success',\n    session_end = CURRENT_TIMESTAMP\nFROM audit.audit_session_log s\nWHERE s.audit_batch_id = @audit_batch_id\n  AND EXISTS (\n      SELECT 1\n      FROM audit.audit_table_session_log t\n      JOIN cfg.cfg_landing_bronze_table c\n          ON t.table_id = c.table_id\n      WHERE t.audit_session_id = s.audit_session_id\n        AND LOWER(t.layer_name) = LOWER(@target_layer)\n        AND c.is_active = 1\n        AND LOWER(c.destination_schema) = LOWER(@target_layer)\n      GROUP BY t.audit_session_id\n      HAVING SUM(CASE WHEN LOWER(t.status) NOT IN ('succeeded', 'success') THEN 1 ELSE 0 END) = 0\n  );\n\nIF NOT EXISTS (\n    SELECT 1\n    FROM audit.audit_table_session_log t\n    JOIN audit.audit_session_log s\n        ON t.audit_session_id = s.audit_session_id\n    JOIN cfg.cfg_landing_bronze_table c\n        ON t.table_id = c.table_id\n    WHERE s.audit_batch_id = @audit_batch_id\n      AND LOWER(t.layer_name) = LOWER(@target_layer)\n      AND c.is_active = 1\n      AND LOWER(c.destination_schema) = LOWER(@target_layer)\n      AND LOWER(t.status) NOT IN ('succeeded', 'success')\n)\nBEGIN\n    EXEC audit.sp_audit_batch_log\n        @action = 'success',\n        @audit_batch_id = @audit_batch_id;\nEND;",
                "type": "Expression"
              },
              "type": "NonQuery"
            }
          ],
          "scriptBlockExecutionTimeout": "02:00:00"
        },
