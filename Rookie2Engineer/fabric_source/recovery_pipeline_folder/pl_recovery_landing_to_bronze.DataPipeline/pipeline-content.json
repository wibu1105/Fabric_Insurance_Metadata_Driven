      {
        "type": "Script",
        "typeProperties": {
          "scripts": [
            {
              "text": {
                "value": "DECLARE @audit_batch_id VARCHAR(100) = '@{replace(string(pipeline().parameters.p_audit_batch_id), '''', '''''')}';\nDECLARE @target_layer VARCHAR(100) = 'bronze';\n\nSELECT\n    s.audit_batch_id,\n    b.batch_status,\n    s.audit_session_id,\n    s.pipeline_name,\n    s.session_status,\n    t.audit_table_session_id,\n    t.table_id,\n    t.layer_name,\n    t.load_type,\n    t.status AS table_status,\n    CAST(t.start_time AS VARCHAR(33)) AS start_time,\n    CAST(t.end_time AS VARCHAR(33)) AS end_time,\n    t.processed_rows,\n    CAST(t.created_at AS VARCHAR(33)) AS created_at,\n    CAST(t.updated_at AS VARCHAR(33)) AS updated_at,\n    c.source_system,\n    c.source_schema,\n    c.source_table,\n    c.source_watermark_column,\n    c.destination_system,\n    c.destination_schema,\n    c.destination_table,\n    c.primary_key_column\nFROM audit.audit_table_session_log t\nJOIN audit.audit_session_log s\n    ON t.audit_session_id = s.audit_session_id\nJOIN audit.audit_batch_log b\n    ON s.audit_batch_id = b.audit_batch_id\nJOIN cfg.cfg_landing_bronze_table c\n    ON t.table_id = c.table_id\nWHERE s.audit_batch_id = @audit_batch_id\n  AND LOWER(t.layer_name) = LOWER(@target_layer)\n  AND LOWER(t.status) NOT IN ('succeeded', 'success')\n  AND c.is_active = 1\n  AND LOWER(c.destination_schema) = LOWER(@target_layer)\nORDER BY COALESCE(t.updated_at, t.created_at, t.start_time), t.table_id;",
                "type": "Expression"
              },
              "type": "Query"
            }
          ],
          "scriptBlockExecutionTimeout": "02:00:00"
        },
